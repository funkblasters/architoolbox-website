{
  "headers": [
    {
      "source": "/toolbox.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/releases/:tool/latest.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/download/dxfcleaner",
      "destination": "https://yourname.gumroad.com/l/dxfcleaner",
      "permanent": true
    },
    {
      "source": "/download/datcleaner",
      "destination": "https://yourname.gumroad.com/l/datcleaner",
      "permanent": true
    },
    {
      "source": "/upgrade/dxfcleaner",
      "destination": "https://yourname.gumroad.com/l/dxfcleaner-upgrade",
      "permanent": false
    },
    {
      "source": "/upgrade/datcleaner",
      "destination": "https://yourname.gumroad.com/l/datcleaner-upgrade",
      "permanent": false
    }
  ]
}
