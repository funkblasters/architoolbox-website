#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASES_DIR="$SCRIPT_DIR/releases"
TOOLBOX_JSON="$SCRIPT_DIR/toolbox.json"

# ── Colors ────────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' BOLD='\033[1m' DIM='\033[2m' RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' BOLD='' DIM='' RESET=''
fi

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
ok()   { echo -e "  ${GREEN}✓${RESET} $*"; }
note() { echo -e "  ${YELLOW}!${RESET} $*"; }

usage() {
    cat >&2 <<EOF

${BOLD}Usage:${RESET}
  $(basename "$0") -A <appname> ( -P | -M | -B | -V <version> ) [-D]
  $(basename "$0") -R

${BOLD}Options:${RESET}
  -A, --appname <name>    App to release — must exist as releases/<name>/
  -P, --patch             Bump patch   (1.2.3 → 1.2.4)
  -M, --minor             Bump minor   (1.2.3 → 1.3.0, resets patch)
  -B, --bump              Bump major   (1.2.3 → 2.0.0, resets minor and patch)
  -V, --version <ver>     Set explicit version (must be > current, format X.Y.Z)
  -D, --dev               Update toolbox.dev.json only (skip toolbox.json)
  -R, --reset             Reset toolbox.dev.json to match toolbox.json + test-app at 1.0.0

${BOLD}Examples:${RESET}
  $(basename "$0") --appname dxfcleaner --patch
  $(basename "$0") -A datcleaner -M
  $(basename "$0") -A dxfcleaner -V 1.3.0
  $(basename "$0") -A test-app -P -D
  $(basename "$0") -R

EOF
    exit 1
}

# ── Argument parsing ──────────────────────────────────────────────────────────
appname=''
mode=''          # patch | minor | major | explicit | reset
new_explicit=''
dev_only=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -A|--appname)
            [[ $# -ge 2 ]] || die "--appname requires an argument"
            appname="$2"; shift 2 ;;
        -P|--patch)
            [[ -z "$mode" ]] || die "only one of -P/-M/-B/-V/-R is allowed"
            mode=patch; shift ;;
        -M|--minor)
            [[ -z "$mode" ]] || die "only one of -P/-M/-B/-V/-R is allowed"
            mode=minor; shift ;;
        -B|--bump)
            [[ -z "$mode" ]] || die "only one of -P/-M/-B/-V/-R is allowed"
            mode=major; shift ;;
        -V|--version)
            [[ $# -ge 2 ]] || die "--version requires an argument"
            [[ -z "$mode" ]] || die "only one of -P/-M/-B/-V/-R is allowed"
            mode=explicit
            new_explicit="$2"; shift 2 ;;
        -D|--dev)
            dev_only=true; shift ;;
        -R|--reset)
            [[ -z "$mode" ]] || die "only one of -P/-M/-B/-V/-R is allowed"
            mode=reset; shift ;;
        -h|--help) usage ;;
        *) die "unknown option: $1" ;;
    esac
done

# ── Reset mode: rebuild toolbox.dev.json from toolbox.json + fresh test-app ───
if [[ "$mode" == "reset" ]]; then
    [[ -f "$TOOLBOX_JSON" ]] || die "toolbox.json not found"
    dev_json="$SCRIPT_DIR/toolbox.dev.json"
    test_latest="$RELEASES_DIR/test-app/latest.json"

    python3 - "$TOOLBOX_JSON" "$dev_json" "$test_latest" <<'PYEOF'
import json, sys

toolbox_json  = sys.argv[1]
dev_json      = sys.argv[2]
test_latest   = sys.argv[3]

with open(toolbox_json) as f:
    data = json.load(f)

# Remove test-app if somehow present, then append fresh baseline
data['tools'] = [t for t in data['tools'] if t.get('id') != 'test-app']
data['tools'].append({
    "id": "test-app",
    "name": "Test App",
    "description": "Ambiente di test per aggiornamenti e upgrade",
    "status": "stable",
    "latest": "1.0.0",
    "latest_by_major": {"1": "1.0.0"},
    "download_url": "https://architoolbox.io/download/test-app",
    "icon_url": "https://www.architoolbox.io/icons/test-app.svg",
    "accent": "oklch(0.55 0.22 270)"
})

with open(dev_json, 'w') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')

with open(test_latest, 'w') as f:
    json.dump({"version": "1.0.0", "latest_by_major": {"1": "1.0.0"},
               "download_url": "https://architoolbox.io/download/test-app"},
              f, indent=2, ensure_ascii=False)
    f.write('\n')
PYEOF

    echo ""
    ok "toolbox.dev.json reset to match toolbox.json"
    ok "releases/test-app/latest.json → 1.0.0"
    echo ""
    exit 0
fi

[[ -n "$appname" ]] || die "-A/--appname is required"
[[ -n "$mode"    ]] || die "one of -P, -M, -B, -V is required"

# ── Validate app ──────────────────────────────────────────────────────────────
releases_app_dir="$RELEASES_DIR/$appname"
latest_json="$releases_app_dir/latest.json"

[[ -d "$releases_app_dir" ]] || die "'$appname' not found — expected directory: $releases_app_dir"
[[ -f "$latest_json"      ]] || die "missing latest.json for '$appname': $latest_json"

# ── Read current version ──────────────────────────────────────────────────────
current=$(python3 -c "
import json, sys
with open('$latest_json') as f:
    d = json.load(f)
v = d.get('version', '')
if not v:
    print('ERROR: no version field in latest.json', file=sys.stderr); sys.exit(1)
print(v)
") || die "could not read version from $latest_json"

is_semver() { [[ "$1" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$ ]]; }

is_semver "$current" || die "current version '$current' in latest.json is not valid semver (X.Y.Z)"

IFS='.' read -r cur_major cur_minor cur_patch <<< "$current"

# ── Compute new version ───────────────────────────────────────────────────────
case "$mode" in
    patch)
        new_version="$cur_major.$cur_minor.$((cur_patch + 1))" ;;
    minor)
        new_version="$cur_major.$((cur_minor + 1)).0" ;;
    major)
        new_version="$((cur_major + 1)).0.0" ;;
    explicit)
        is_semver "$new_explicit" \
            || die "version '$new_explicit' is not valid semver (X.Y.Z, no leading zeros)"

        IFS='.' read -r new_major new_minor new_patch <<< "$new_explicit"

        # Must be strictly greater than current
        is_greater=false
        if   (( new_major >  cur_major )); then is_greater=true
        elif (( new_major == cur_major && new_minor >  cur_minor )); then is_greater=true
        elif (( new_major == cur_major && new_minor == cur_minor && new_patch > cur_patch )); then is_greater=true
        fi

        if [[ "$is_greater" != true ]]; then
            die "'$new_explicit' must be strictly greater than current '$current'"
        fi

        new_version="$new_explicit" ;;
esac

# ── Extract new major ─────────────────────────────────────────────────────────
IFS='.' read -r new_major _ _ <<< "$new_version"

# ── Collect changelog for major releases ─────────────────────────────────────
changelog=""
if (( new_major > cur_major )) && [[ -f "$TOOLBOX_JSON" ]]; then
    echo -e "\n${BOLD}Novità in v${new_version}${RESET} ${DIM}(riga vuota per terminare)${RESET}"
    lines=()
    while true; do
        printf "  › "
        IFS= read -r line || break
        [[ -z "$line" ]] && break
        lines+=("$line")
    done
    if (( ${#lines[@]} > 0 )); then
        printf -v changelog '%s\n' "${lines[@]}"
        changelog="${changelog%$'\n'}"
    fi
fi

_changelog_file=$(mktemp)
trap 'rm -f "$_changelog_file"' EXIT
printf '%s' "$changelog" > "$_changelog_file"

# ── Confirm and update ────────────────────────────────────────────────────────
echo -e "\n${BOLD}$appname${RESET}  ${DIM}$current${RESET} → ${YELLOW}$new_version${RESET}\n"

python3 -c "
import json
with open('$latest_json') as f:
    data = json.load(f)
data['version'] = '$new_version'
lbm = data.setdefault('latest_by_major', {})
lbm['$new_major'] = '$new_version'
with open('$latest_json', 'w') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
"
ok "releases/$appname/latest.json"

# ── Update catalog files that list this app ───────────────────────────────────
any_catalog_updated=false
if [[ "$dev_only" == true ]]; then
    catalog_files=("$SCRIPT_DIR/toolbox.dev.json")
else
    catalog_files=("$SCRIPT_DIR/toolbox.json" "$SCRIPT_DIR/toolbox.dev.json")
fi
for catalog_file in "${catalog_files[@]}"; do
    [[ -f "$catalog_file" ]] || continue
    label=$(basename "$catalog_file")
    result=$(python3 - "$catalog_file" "$appname" "$new_version" "$new_major" "$_changelog_file" <<'PYEOF'
import json, sys

toolbox_json   = sys.argv[1]
appname        = sys.argv[2]
new_version    = sys.argv[3]
new_major      = sys.argv[4]
changelog_file = sys.argv[5]

with open(changelog_file) as cf:
    changelog = cf.read()

with open(toolbox_json) as f:
    data = json.load(f)

found = False
for tool in data.get('tools', []):
    if tool.get('id') == appname and tool.get('status') != 'coming-soon':
        tool['latest'] = new_version
        lbm = tool.setdefault('latest_by_major', {})
        lbm[new_major] = new_version
        if changelog:
            notes = tool.setdefault('upgrade_notes', {})
            notes[new_major] = changelog
        found = True

with open(toolbox_json, 'w') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')

print('updated' if found else 'not-found')
PYEOF
)
    if [[ "$result" == "updated" ]]; then
        ok "$label"
        any_catalog_updated=true
    fi
done

if [[ "$any_catalog_updated" == false ]]; then
    note "'$appname' not found in any catalog — only latest.json updated"
fi

if [[ -n "$changelog" ]] && [[ "$any_catalog_updated" == true ]]; then
    ok "upgrade_notes[\"$new_major\"] written"
elif (( new_major > cur_major )) && [[ -z "$changelog" ]]; then
    note "No changelog entered — upgrade_notes[\"$new_major\"] not set"
fi

echo ""
